<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "//mybatis.org/DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.nepnep.querymaker.mapper.QueryMakerMapper">

	<select id="test" resultType="String" parameterType="String">
		${testQuery}
	</select>


	<resultMap id="boardResultMap" type="com.nepnep.querymaker.model.BoardVO">
		<result column="SEQ" property="seq"/>
		<result column="TITLE" property="title"/>
		<result column="CONT" property="cont"/>
		<result column="REG_DATE" property="regDate"/>
		<result column="REG_USER" property="regUser"/>
		<result column="UPD_DATE" property="updDate"/>
		<result column="UPD_USER" property="updUser"/>
	</resultMap>

	<select id="select1" resultMap="boardResultMap" parameterType="String">
		${testQuery}
	</select>
  
  
</mapper>